{
  "pipeline": [
    {
      "op": "time_window",
      "start": 0,
      "end": 5000
    },
    {
      "op": "filter_type",
      "keep": ["reaction"]
    },
    {
      "op": "min_edge_weight",
      "min": 3
    },
    {
      "op": "min_node_freq",
      "min": 5,
      "source": "events",
      "use_degree_proxy": true
    },
    {
      "op": "k_core",
      "k": 2,
      "mode": "undirected"
    },
    {
      "op": "neighborhood",
      "seeds": ["CO|smiles=[C]=O"],
      "depth": 2,
      "mode": "undirected"
    },
    {
      "op": "shortest_paths",
      "sources": ["CO|smiles=[C]=O"],
      "targets": ["CO2|smiles=O=C=O"],
      "mode": "directed"
    },
    {
      "op": "collapse_reversible"
    }
  ],
  "prune_isolates": true
}